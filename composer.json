{
  "name": "smartroom/finder",
  "description": "Smart Room Finder - Hệ thống tìm kiếm phòng trọ thông minh",
  "type": "project",
  "license": "MIT",
  "require": {
    "php": "^8.0",
    "cloudinary/cloudinary_php": "^3.1"
  },
  "require-dev": {
    "phpunit/phpunit": "^9.5"
  },
  "autoload": {
    "psr-4": {
      "App\\": "app/",
      "Core\\": "core/"
    },
    "files": [
      "core/bootstrap.php"
    ]
  },
  "scripts": {
    "server": "php -S localhost:8000 -t public/",
    "test": "phpunit",
    "migrate": "php database/migrate.php"
  }
}
